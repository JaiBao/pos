const stringOptions = ref([])

const fetchOptions = async () => {
  let currentPage = 1
  while (currentPage) {
    const { data } = await apiAuth.get(/member/member?page=${currentPage}`)
    const { current_page: currentPageNum, data: currentData } = data
    currentData.forEach(({ mobile }) => {
      if (mobile) {
        options.value.push(mobile)
      }
    })
    if (currentPageNum < data.last_page) {
      currentPage++
    } else {
      currentPage = null
    }
  }
}

fetchOptions()

const filterFn = (val, update, abort) => {
  if (val.length < 3) {
    abort()
    return
  }

  update(() => {
    const needle = val.toLowerCase()
    return options.value.filter(v => v.toLowerCase().indexOf(needle) > -1)
  })
}
